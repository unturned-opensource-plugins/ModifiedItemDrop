<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>latest</LangVersion>
    <NoWarn>$(NoWarn);8632</NoWarn>
    <RootNamespace>FFEmqo.ModifiedItemDrop</RootNamespace>
    <Version>2.0.0</Version>
    <AssemblyVersion>2.0.0.0</AssemblyVersion>
    <FileVersion>2.0.0.0</FileVersion>
    <InformationalVersion>2.0.0</InformationalVersion>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
	  <PackageReference Include="RestoreMonarchy.RocketRedist" Version="3.*" ExcludeAssets="runtime" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="tempInspect\**\*.cs" />
    <Compile Remove="ModifiedItemDrop.Domain\bin\**\*.cs" />
    <Compile Remove="ModifiedItemDrop.Domain\obj\**\*.cs" />
    <Compile Remove="ModifiedItemDrop.Domain.Tests\**\*.cs" />
    <Compile Remove="参考插件\**" />
    <EmbeddedResource Remove="tempInspect\**\*" />
    <EmbeddedResource Remove="ModifiedItemDrop.Domain\bin\**\*" />
    <EmbeddedResource Remove="ModifiedItemDrop.Domain\obj\**\*" />
    <EmbeddedResource Remove="ModifiedItemDrop.Domain.Tests\**\*" />
    <EmbeddedResource Remove="参考插件\**" />
    <None Remove="tempInspect\**\*" />
    <None Remove="ModifiedItemDrop.Domain\bin\**\*" />
    <None Remove="ModifiedItemDrop.Domain\obj\**\*" />
    <None Remove="ModifiedItemDrop.Domain.Tests\**\*" />
    <None Remove="参考插件\**" />
  </ItemGroup>

</Project>